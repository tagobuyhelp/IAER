# Redirect www to non-www
server {
    listen 80;
    listen [::]:80;
    server_name www.iaer.ac.in;
    return 301 https://iaer.ac.in$request_uri;
}

server {
    listen 80;
    listen [::]:80;
    listen 443 ssl http2;
    listen [::]:443 ssl http2;

    server_name iaer.ac.in www.iaer.ac.in;

    # Correct SSL files
    ssl_certificate     /etc/letsencrypt/live/iaer.ac.in/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/iaer.ac.in/privkey.pem;

    # CSP & security headers
    add_header Content-Security-Policy "default-src 'self' https:; script-src 'self' 'unsafe-inline' https://in8cdn.npfs.co https://widgets.in8.nopaperforms.com https://chatbot.in8.nopaperforms.com https://chatcdn.npfs.co https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline' https:; img-src 'self' data: https:; frame-src https://widgets.in8.nopaperforms.com https://chatbot.in8.nopaperforms.com https://www.youtube.com https://www.google.com https://www.google.co.in https://www.imas.ac.in/uploads/files/IMAS_Mandatoy_DIsclosure.pdf; connect-src 'self' https://in8cdn.npfs.co https://widgets.in8.nopaperforms.com https://chatbot.in8.nopaperforms.com https://chatcdn.npfs.co https://www.googletagmanager.com https://www.google-analytics.com;" always;

    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "no-referrer-when-downgrade" always;
    add_header X-Frame-Options ALLOWALL;

    # React app reverse proxy
    location / {
        proxy_pass http://127.0.0.1:4000/;
        proxy_http_version 1.1;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header Host $host;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
