server {
    server_name iaer.ac.in www.iaer.ac.in;

    # Redirect HTTP → HTTPS
    location / {
        proxy_pass http://127.0.0.1:4000;

        proxy_http_version 1.1;

        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;

        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_cache_bypass $http_upgrade;
    }

    # Basic security headers
    add_header X-Content-Type-Options nosniff always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "no-referrer-when-downgrade" always;
    add_header Content-Security-Policy "default-src 'self' https:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https:; style-src 'self' 'unsafe-inline' https:; img-src 'self' data: https:; frame-src 'self' https:; connect-src 'self' https: wss:; frame-ancestors 'self' https://*.nopaperforms.com https://*.npfs.co;" always;

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/iaer.ac.in/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/iaer.ac.in/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot
}

server {
    if ($host = www.iaer.ac.in) {
        return 301 https://$host$request_uri;
    } # managed by Certbot

    if ($host = iaer.ac.in) {
        return 301 https://$host$request_uri;
    } # managed by Certbot

    listen 80;
    server_name iaer.ac.in www.iaer.ac.in;
    return 404; # managed by Certbot
}
